            }
        ],
        "profiles": [
            {
                "name": "hnsw-profile",
                "algorithm": "hnsw-cfg",
                "vectorizer": "aoai-vectorizer"
            }
        ]
    },
    "semantic": {
        "configurations": [
            {
                "name": "default",
                "prioritizedFields": {
                    "titleField": {
