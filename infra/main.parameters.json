{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "environmentName": {
            "value": "${AZURE_ENV_NAME=voicebot}"
        },
        "location": {
            "value": "${AZURE_LOCATION=swedencentral}"
        },
        "chatModelName": {
            "value": "${AZURE_OPENAI_CHAT_MODEL=gpt-4.1-mini}"
        },
        "chatModelVersion": {
            "value": "${AZURE_OPENAI_CHAT_MODEL_VERSION=2025-04-14}"
        },
        "embeddingModelName": {
            "value": "${AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large}"
        },
        "realtimeModelName": {
            "value": "${AZURE_OPENAI_REALTIME_MODEL=gpt-realtime-mini}"
        },
        "realtimeModelVersion": {
            "value": "${AZURE_OPENAI_REALTIME_MODEL_VERSION=2025-12-15}"
        },
        "principalId": {
            "value": "${AZURE_PRINCIPAL_ID=}"
        }
    }
}